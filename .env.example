# Copy this file to .env.local after the backend branch is merged.
# The frontend mock demo runs without keys.

# Anthropic: per-turn analysis and final verdict
ANTHROPIC_API_KEY=

# Deepgram: speech-to-text, diarization, and text-to-speech
DEEPGRAM_API_KEY=

# Redis Stack vector search
# Local option: docker run -d --name debate-redis -p 6379:6379 redis/redis-stack:latest
REDIS_URL=redis://localhost:6379

# --- Demo pipeline (Batch 5/6) ---
# Path to the recorded demo clip. If unset, the app uses the first audio file
# found in samples/.
DEMO_CLIP_PATH=
# Topic shown for the demo debate.
DEMO_TOPIC=Pineapple belongs on pizza.
# Flip the UI from mock replay to the real live pipeline (needs keys + a clip).
NEXT_PUBLIC_USE_REAL_PIPELINE=false
