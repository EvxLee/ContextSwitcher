# Copy this file to .env.local. The scripted courtroom demo runs without keys.

# Claude: per-turn analysis and final verdict
ANTHROPIC_API_KEY=

# Deepgram: live transcription, speaker diarization, and referee voice
DEEPGRAM_API_KEY=

# Redis Stack: vector retrieval for the fallacy reference library
# Local option: docker run -d --name debate-redis -p 6379:6379 redis/redis-stack:latest
REDIS_URL=redis://localhost:6379

# Optional recorded-demo pipeline
DEMO_CLIP_PATH=
DEMO_TOPIC=Pineapple belongs on pizza.
NEXT_PUBLIC_USE_REAL_PIPELINE=false
